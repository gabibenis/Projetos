def deriva_cor(estrela):
    """
    Deriva a cor (classe espectral) de uma estrela.

    Parâmetros:
      * estrela (pandas.Series): entrada do catálogo que corresponde a estrela
        a qual deseja-se derivar a cor.

    Devolve:
      * cor (str): string de um caractér que representa a cor da estrela
        passada como argumento. Os valores que `cor` pode assumir são: "O",
        "A", "F", "G", "K" ou "M".

    Dicas:
      * Ler campos de um `pandas.Series` é igual a ler campos de um dicionário.
      * A forma de se derivar a cor a partir das características de uma estrela
        está descrita no enunciado do EP3. Não tente adivinhar como derivá-la
        ou utilizar uma outra referência!
    """
    ### inicio
    temperatura = estrela['temperatura']
    if temperatura >= 33000:
        return 'O'
    elif 10000 < temperatura < 33000:
        return 'B'
    elif 7300 < temperatura <= 10000:
        return 'A'
    elif 6000 < temperatura <= 7300:
        return 'F'
    elif 5300 < temperatura <= 6000:
        return 'G'
    elif 3900 < temperatura <= 5300:
        return 'K'
    else:
        return 'M'

def gera_catalogo_com_cor(catalogo):
    """
    Usa um catálogo de estrelas para gerar um novo catálogo estendido que
    contém as cores (classes espectrais) das estrelas. Este novo catálogo é
    idêntico ao passado como argumento (o catálogo base) apenas adicionado da
    coluna `cor`.

    Parâmetros:
      * catalogo (pandas.DataFrame): dataframe com catálogo de estrelas.

    Devolve:
      * catalogo_com_cor (pandas.DataFrame): extensão de `catalogo` com a
        coluna `cor` adicionada.

    Dicas:
      * Não tente modificar `catalogo`. Crie uma cópia dele e modifique a
        cópia.
      * Primeiro crie a coluna `cor` com um valor qualquer, e então passe por
        cada entrada atualizando o campo `cor` de acordo.
      * Use a função `deriva_cor()`.
    """
    ### inicio
    catalogo_com_cor = catalogo.copy()
    cores = []
    for i, estrela in catalogo.iterrows():
        cores.append(deriva_cor(estrela))
    catalogo_com_cor["cor"] = cores
    return catalogo_com_cor

