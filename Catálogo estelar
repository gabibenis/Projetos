def coleta_rotas(catalogo):
    max_id = catalogo.index.max()
    min_id = catalogo.index.min()
    input_valido = True
    coleta_rota = True
    rotas = []

    print("Uma rota é uma lista de (pelo menos 2) IDs separados por vírgulas.")
    print("Entre uma rota vazia (sem nenhum caractere) para encerrar a adição.")
    i = 0
    while coleta_rota:
        ids_str = input(f"Rota {i}: ")
        if len(ids_str) == 0:
            coleta_rota = False
        else:
            ids = []
            for ID in ids_str.split(","):
                ids.append(int(ID.strip()))
            for ID in ids:
                if not (min_id <= ID <= max_id):
                    input_valido = False
                    coleta_rota = False
            if len(ids) < 2:
                input_valido = False
                coleta_rota = False
            rotas.append(ids)
        i += 1

    return input_valido, rotas


