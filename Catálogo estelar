def deriva_coord_cart(estrela):
    """
    Deriva as coordenadas cartesianas de uma estrela.

    Parâmetros:
      * estrela (pandas.Series): entrada do catálogo que corresponde a estrela
        a qual deseja-se derivar as coordenadas cartesianas.

    Devolve:
      * x (float): coordenada X da estrela.
      * y (float): coordenada Y da estrela.
      * z (float): coordenada Z da estrela.

    Dicas:
      * Use as funções `radians()`, `sin()` e `cos()` da biblioteca `math`.
      * Atente-se que os ângulos de ascensão reta (coluna `ascensao_reta`) e
        declinação (coluna `declinacao`) estão em graus e não radianos.
      * A forma de se derivar as coordenadas cartesianas a partir das
        características de uma estrela estão descritas no enunciado do EP3. Não
        tente adivinhar como derivá-las ou utilizar uma outra referência!
    """
    ### inicio
    a = math.radians(estrela['ascensao_reta'])
    b = math.radians(estrela['declinacao'])
    c = estrela['distancia']
    x = c * math.cos(b) * math.cos(a)
    y = c * math.cos(b) * math.sin(a)
    z = c * math.sin(b)
    return x, y, z

def calcula_distancia(estrela_1, estrela_2):
    """
    Calcula a distância entre duas estrelas.

    Parâmetros:
      * estrela_1 (pandas.Series): entrada do catálogo que corresponde a uma
        estrela.
      * estrela_2 (pandas.Series): entrada do catálogo que corresponde a uma
        estrela.

    Devolve:
      * d (float): disância entre a `estrela_1` e a `estrela_2`.

    Dicas:
      * Use a função `deriva_coord_cart()`.
      * Use a função `abs()` para calcular o valor absoluto de um número.
      * A fórmula de distância entre dois pontos cartesianos está descrita no
        enunciado do EP3. Não tente adivinhá-la ou utilizar uma outra
        referência!
    """
    ### inicio
    x1, y1, z1 = deriva_coord_cart(estrela_1)
    x2, y2, z2 = deriva_coord_cart(estrela_2)
    distancia = math.sqrt((x1 - x2)**2 + (y1 - y2)**2 + (z1 - z2)**2)
    return distancia

def checa_rotas(catalogo, rotas, d_max):
    """
    Checa se uma sequência de rotas estelares é viável baseado em um catálogo
    de estrelas e uma distância máxima. Para cada rota na sequência de rotas
    (definida por argumento), a função usa o catálogo de estrelas (definido por
    argumento) e a distância máxima (definida por argumento) para checar se
    *cada* trecho da rota ultrapassa a distância máxima. Se *nenhum* trecho da
    rota ultrapassar esta distância, então a rota é considerada viável, e
    vice-versa.

    Parâmetros:
      * catalogo (pandas.DataFrame): dataframe com catálogo de estrelas.
      * rotas (list(list(int))): lista com listas de IDs, representando as
        rotas as serem checadas. Por exemplo, duas rotas 4-2344-35 e 1842-245
        são representadas como `rotas = [[4, 2344, 35], [1842, 245]]`.
      * d_max (float): distancia máxima entre *cada* trecho da rota.

    Devolve:
      * viabilidade_rotas (list(bool)): lista de booleanos que representa a
        viabilidade de `rotas`. Por exemplo, considerando `rotas = [[4, 2344,
        35], [1842, 245]]` e `d_max = 42`, se *apenas* o trecho 2344-35 tem
        distância maior que 42, então temos `viabilidade_rotas = [False, True]`.

    Dicas:
      * Utilize um laço aninhado para percorrer cada rota em `rotas` e cada
        trecho da rota.
      * Note que em uma rota com 3 estrelas há 2 trechos (da 1a estrela à 2a
        estrela e da 2a estrela à 3a estrela), então atente-se a "onde começar"
        um dos laços.
    """
    ### inicio
    viabilidade_rotas = []
    for rota in rotas:
        viavel = True
        roda = True
        if roda:
          for i in range(len(rota) - 1):
              estrela_1 = catalogo.loc[rota[i]]
              estrela_2 = catalogo.loc[rota[i + 1]]
              if calcula_distancia(estrela_1, estrela_2) > d_max:
                  viavel = False
                  roda = False
        viabilidade_rotas.append(viavel)
    return viabilidade_rotas

def imprime_viabilidade_rotas(rotas, viabilidade_rotas):
    """
    Imprime as rotas estelares viáveis e as inviáveis.

    Parâmetros:
      * rotas (list(list(int))): lista com listas de IDs, representando as
        rotas as serem checadas. Por exemplo, duas rotas 4-2344-35 e 1842-245
        são representadas como `rotas = [[4, 2344, 35], [1842, 245]]`.
      * viabilidade_rotas (list(bool)): lista de booleanos que representa a
        viabilidade de `rotas`. Por exemplo, considerando `rotas = [[4, 2344,
        35], [1842, 245]]` e `d_max = 42`, se *apenas* o trecho 2344-35 tem
        distância maior que 42, então temos `viabilidade_rotas = [False, True]`.

    Dicas:
      * Primeiro construa a lista das rotas viáveis e inviáveis, depois itere
        sobre cada uma imprimindo.
      * Ao adicionar uma rota a uma das listas (viáveis ou inviáveis), use um
        dicionário para "não esquecer" o número da rota.
    """
    ### inicio
    rotas_viaveis = []
    rotas_inviaveis = []
    for i in range(len(viabilidade_rotas)):
        if viabilidade_rotas[i]:
            rotas_viaveis.append(f"Rota {i}: {rotas[i]}")
        else:
            rotas_inviaveis.append(f"Rota {i}: {rotas[i]}")
    print("Rotas viáveis:")
    for rota in rotas_viaveis:
        print(f"- {rota}")
    print("Rotas inviáveis:")
    for rota in rotas_inviaveis:
        print(f"- {rota}")

