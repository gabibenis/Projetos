def gera_estatisticas_gerais(catalogo):
    """
    Gera estatísticas gerais sobre um catálogo de estrelas. As estatísticas
    gerais são:
      - Número total de estrelas
      - Massa total das estrelas
      - Temperatura média das estrelas
      - Mediana da luminosidade das estrelas

    As estatísticas gerais são devolvidas em um dicionário (dict) na forma:
    ```
    {
        "total_estrelas": <n-total-estrelas>,
        "massa_total": <massa-total-estrelas>,
        "temperatura_media": <temperatura-media>,
        "mediana_luminosidade": <mediana-luminosidade>
    }
    ```

    IMPORTANTE: siga rigorosamente o formato do dicionário descrito acima, isto
    é, defina as chaves com nomes idênticos aos de acima.

    Parâmetros:
      * catalogo (pandas.DataFrame): dataframe com catálogo de estrelas.

    Devolve:
      * estatisticas_gerais (dict): dicionário com estatísticas gerais.

    Dicas:
      * Use as funções `len()`, `mean()`, `median()` e `sum()`.
      * Não se preocupe em arredondar os valores.
    """
    ### inicio
    total_estrelas = len(catalogo)
    massa_total = catalogo['massa'].sum()
    temperatura_media = catalogo['temperatura'].mean()
    mediana_luminosidade = catalogo['luminosidade'].median()

    estatisticas_gerais = {
        "total_estrelas": total_estrelas,
        "massa_total": massa_total,
        "temperatura_media": temperatura_media,
        "mediana_luminosidade": mediana_luminosidade
        }
    return  estatisticas_gerais

