def filtra_catalogo(catalogo, coluna, op_comp, valor):
    """
    Filtra um catálogo de estrelas sob valores de uma coluna. Isto é, a partir
    de um catálogo passado como argumento, filtra apenas as entradas (linhas)
    que tiverem valores em uma dada coluna (definida por argumento) que são <,
    <=, ==, >=, ou > (definido por argumento) que um dado valor (definido por
    argumento).

    IMPORTANTE: assuma que apenas colunas com valores númericos são passadas
    como argumento.

    Parâmetros:
      * catalogo (pandas.DataFrame): dataframe com catálogo de estrelas.
      * coluna (str): string correspondendo a nome da coluna que se deseja usar
        para filtrar.
      * op_comp (int): inteiro de 1 a 5 representando a operação de comparação
        que se deseja aplicar. O mapeamento do valor de `op_comp` com os
        operadores é: 1: <, 2: <=, 3: ==, 4: >=, ou 5: >.
      * valor (float): valor numérico a ser comparado na filtragem.

    Devolve:
      * catalogo_filtrado (pandas.DataFrame): dataframe com catálogo de
        estrelas que foi filtrado com base nos argumentos passados.

    Dicas:
      * Use `valor` para compor o filtro, ou seja,
        `filtro = ... valor`
      * O filtro é um `pandas.Series` (um "dataframe de uma só coluna"), que
        contém booleanos dizendo se a entrada atende (`True`) ou não (`False`)
        a comparação.
      * Para gerar `catalogo_filtrado`, "aplique" o filtro criado em uma
        operação sobre `catalogo`.
    """
    ### inicio
    (catalogo, coluna, op_comp, valor)
    if op_comp == 1:
      filtro = catalogo[coluna] < valor
    elif op_comp == 2:
      filtro = catalogo[coluna] <= valor
    elif op_comp == 3:
      filtro = catalogo[coluna] == valor
    elif op_comp == 4:
      filtro = catalogo[coluna] >= valor
    elif op_comp == 5:
      filtro = catalogo[coluna] > valor
    catalogo_filtrado = catalogo[filtro]
    return catalogo_filtrado

