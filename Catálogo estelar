def coleta_ids_colunas(catalogo):
    input_valido = True

    ids_str = input("Entre os IDs separados por vírgulas: ")
    ids = []
    for ID in ids_str.split(","):
        ids.append(int(ID.strip()))
    max_id = catalogo.index.max()
    min_id = catalogo.index.min()
    for ID in ids:
        if not (min_id <= ID <= max_id):
            input_valido = False

    colunas_str = input("Entre as colunas separadas por vírgulas: ")
    colunas = []
    for coluna in colunas_str.split(","):
        colunas.append(coluna.strip())
    for coluna in colunas:
        if coluna not in list(catalogo.columns):
            input_valido = False

    return input_valido, ids, colunas

