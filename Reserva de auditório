def filtrar_por_categoria(reservas):
    """
    Opção 2: Solicita uma categoria e lista as reservas que pertencem a ela.
    """
    # Adicione seu código aqui.
    categoria = input('Digite a categoria desejada (Externo/USP): ')
    if categoria == 'Externo':
      print('--- RESERVAS DA CATEGORIA EXTERNO ---')
    if categoria == 'USP':
      print('--- RESERVAS DA CATEGORIA USP ---')
    for coluna in reservas:
      if categoria == 'Externo' and coluna[3] == 'Externo':
        print()
        print(f'ID Reserva: {coluna[0]}')
        print(f'Solicitante: {coluna[2]}')
        print(f'Data de Início: {coluna[4]}')
        print(f'Data de Fim: {coluna[8]}')
      elif categoria == 'USP' and coluna[3] == 'USP':
        print()
        print(f'ID Reserva: {coluna[0]}')
        print(f'Solicitante: {coluna[2]}')
        print(f'Data de Início: {coluna[4]}')
        print(f'Data de Fim: {coluna[8]}')

########################################################
def calcular_total_arrecadado(reservas):
    """
    Opção 3: Calcula e exibe o valor total arrecadado por categoria.
    """
    # Adicione seu código aqui.
    print('--- VALOR ARRECADADO POR CATEGORIA ---')
    valorUSP = 0
    valorExterno = 0
    for coluna in reservas:
      if coluna[3] == 'Externo':
        valorExterno += coluna[14]
      else:
        valorUSP += coluna[14]
    print(f'Categoria USP: R$ {valorUSP:.2f}')
    print(f'Categoria Externo: R$ {valorExterno:.2f}')

###############################################333
def exibir_estatisticas(reservas):
    """
    Opção 4: Calcula e exibe estatísticas gerais, como média de diárias e
    percentual de reservas com desconto.
    """
    # Adicione seu código aqui.
    print('--- ESTATÍSTICAS GERAIS ---')
    dias = [0, 31, 28, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31] #dias de cada mes
    contagem = 0 #já considera desde o 1º dia
    clientes = 0 #ou len(reservas[0])?
    nDesconto = 0
    #conatagem de dias
    for coluna in reservas:
      anoI = coluna[7]
      anoF = coluna[11]
      mesI = coluna[6]
      mesF = coluna[10]
      diaI = coluna[5]
      diaF = coluna[9]
      contagem += diaF - diaI + 1 #normaliza os dias do 1º e ultimo mes (se meses iguais de eanos iguais, tambem resolve)
      while anoI < anoF: #normalizar anos
        while mesI <= 12: 
          contagem += dias[mesI]
          mesI += 1
        anoI += 1
        mesI = 1
      while mesI < mesF: #normalizar meses
        contagem += dias[mesI]
        mesI += 1
    #contagem de descontos aplicados
    for coluna in reservas:
      if coluna[13] != 0:
        nDesconto += 1
    #contagem de clientes
    for coluna in reservas:    #ou len(reservas[0])?
      if clientes < coluna[0]:
        clientes = coluna[0]
    #dados calculados
    medDias = contagem/clientes
    porcentual = nDesconto/clientes *100
    #dados impressos
    print(f'Média de diárias por reserva: {medDias} dias')
    print(f'Percentual de reservas com desconto: {round(porcentual)}%')

