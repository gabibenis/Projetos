import pandas as pd

# --- CARREGAMENTO DE DADOS ---
# Esta função já está implementada e é responsável por carregar os dados, não altere.
def carregar_dados(url):
    """
    Carrega os dados da planilha e retorna como uma lista de listas.
    A primeira linha (cabeçalho) é ignorada.
    """
    df = pd.read_csv(url)
    reservas = df.values.tolist()
    return reservas

# --- OPERAÇÕES---
# As funções abaixo já estão declaradas, mas o corpo precisa ser implementado.
# Não altere os nomes nem os parâmetros das funções.

#############################################
def listar_reservas(reservas):
    """
    Opção 1: Lista todas as reservas com suas informações detalhadas.
    Acessa os elementos da sublista pelo índice para imprimir os dados.
    """
    # Adicione seu código aqui.
    print('--- LISTAGEM DE RESERVAS ---')
    for coluna in reservas:
      print()
      print(f'ID Reserva: {coluna[0]}')
      print(f'ID Solicitante: {coluna[1]}')
      print(f'Solicitante: {coluna[2]}')
      print(f'Categoria: {coluna[3]}')
      print(f'Data de Início: {coluna[4]}')
      print(f'Data de Fim: {coluna[8]}')
      print(f'Valor da Diária: R$ {coluna[12]:.2f}')
      print(f'Desconto: R$ {coluna[13]:.2f}')
      print(f'Valor Total: R$ {coluna[14]:.2f}') #olhar como foi feito a formatação dos valores

